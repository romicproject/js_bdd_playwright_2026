# Base URLs
BASE_URL=https://automationexercise.com
API_BASE_URL=https://automationexercise.com/api

# Timeouts (milliseconds)
REQUEST_TIMEOUT=10000
GLOBAL_TIMEOUT=30000

# Test User (local/CI injected values)
TEST_USER_EMAIL=change_me_local@example.com
TEST_USER_PASSWORD=CHANGE_ME_LOCAL

# API Keys (if needed, prefer CI secret variables)
API_KEY=CHANGE_ME_LOCAL

# Retry Settings
RETRY_FAILED_TESTS=0
MAX_RETRIES=0

# LOG - dev profile
LOG_CONSOLE=false
LOG_CONSOLE_LEVEL=warn

LOG_LEVEL=info
LOG_FORMAT=pretty
LOG_COLOR=true
LOG_DIR=out/logs
LOG_ATTACH_ALLURE=false
LOG_API_MAX_BODY=20000

# UI network blocker
UI_BLOCK_ADS=true
UI_BLOCK_RESOURCES=false

# Performance SLO knobs (optional)
PERF_P95_MS=900
PERF_P99_MS=1800
PERF_MIN_SUCCESS_RATE=0.99