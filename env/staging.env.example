# Base URLs
BASE_URL=
API_BASE_URL=

# Timeouts (milliseconds)
REQUEST_TIMEOUT=10000
GLOBAL_TIMEOUT=30000

# Test User (inject via CI/local env where possible)
TEST_USER_EMAIL=
TEST_USER_PASSWORD=

# API Keys
API_KEY=

# Retry Settings
RETRY_FAILED_TESTS=1
MAX_RETRIES=1

# Logging
LOG_CONSOLE=false
LOG_CONSOLE_LEVEL=warn
LOG_LEVEL=info
LOG_FORMAT=jsonl
LOG_COLOR=false
LOG_DIR=out/logs
LOG_ATTACH_ALLURE=true
LOG_API_MAX_BODY=50000

# UI network blocker
UI_BLOCK_ADS=true
UI_BLOCK_RESOURCES=false
