# Base URLs
BASE_URL=
API_BASE_URL=

# Timeouts (milliseconds)
REQUEST_TIMEOUT=10000
GLOBAL_TIMEOUT=30000

# Test User (local/CI injected values)
TEST_USER_EMAIL=
TEST_USER_PASSWORD=

# API Keys (if needed, prefer CI secret variables)
API_KEY=

# Retry Settings
RETRY_FAILED_TESTS=0

# API cleanup policy
API_FAIL_ON_CLEANUP_ERROR=false

# Skip live API preflight in globalSetup (useful when API is down but you want to run @mock lane)
API_SKIP_PREFLIGHT=false

# LOG - dev profile
LOG_CONSOLE=true
LOG_CONSOLE_LEVEL=warn

LOG_LEVEL=debug
LOG_FORMAT=pretty
LOG_COLOR=true
LOG_DIR=out/logs
LOG_ATTACH_ALLURE=false
LOG_API_MAX_BODY=20000

# UI network blocker
UI_BLOCK_ADS=true
UI_BLOCK_RESOURCES=false

# Performance SLO knobs (optional)
PERF_P95_MS=900
PERF_P99_MS=1800
PERF_MIN_SUCCESS_RATE=0.99
